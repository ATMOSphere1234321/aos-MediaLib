<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ripple_orange"
    > <!-- Large radius ensures full spread -->

    <!-- Mask helps define where ripple shows up -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white" />
            <corners android:radius="6dp" />

        </shape>
    </item>

    <!-- Optional: Use this to force background fill -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/transparent_blue" />
            <corners android:radius="6dp" />
            <!--<stroke
                android:width="1dp"
                android:color="@color/resume_stroke_color" />-->
        </shape>
    </item>
</ripple>