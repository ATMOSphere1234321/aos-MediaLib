<?xml version="1.0" encoding="utf-8"?>

<resources>

    <style name="ArchosTheme" parent="Theme.AppCompat">
        <item name="actionBarStyle">@style/Widget.Material.ActionBar.Archos</item>
        <item name="colorPrimary">@color/lightblue500</item>
        <item name="colorPrimaryDark">#002642</item>
        <item name="colorAccent">@color/lightblue400</item>
        <item name="android:navigationBarColor">#001b30</item>
        <item name="alertDialogTheme">@style/Theme.AlertDialog</item>
    </style>

    <style name="Widget.Material.ActionBar.Archos" parent="Widget.AppCompat.ActionBar">
        <item name="background">@null</item>
    </style>

    <style name="ArchosThemeBlueNoActionBar" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/lightblue800</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="actionBarStyle">@style/Widget.Holo.ActionBar.Archos</item>
        <item name="colorPrimary">@color/lightblue500</item>
        <item name="colorPrimaryDark">#002642</item>
        <item name="colorAccent">@color/lightblue400</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <!-- for the hamburger icon -->
        <item name="drawerArrowStyle">@style/DrawerArrowStyle</item>
        <!-- for the overflow icon -->
        <item name="actionOverflowButtonStyle">@style/OverflowButtonStyle</item>
        <!-- for the white back arrow -->
        <item name="colorControlNormal">@android:color/white</item>
        <item name="android:navigationBarColor">#001b30</item>
        <item name="actionOverflowMenuStyle">@style/CustomPopupMenu</item>
        <item name="actionDropDownStyle">@style/Widget.MovieCategory.Spinner</item>
    </style>

    <style name="Widget.MovieCategory.Spinner" parent="Widget.AppCompat.Spinner.DropDown.ActionBar">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:dropDownVerticalOffset">32dp</item> <!-- pushes dropdown below spinner -->
        <item name="android:popupBackground">@drawable/movie_spinner_dropdown_bg</item>
        <item name="android:dropDownSelector">@android:color/transparent</item>
    </style>

    <style name="DrawerArrowStyle" parent="Widget.AppCompat.DrawerArrowToggle">
        <item name="spinBars">true</item>
        <item name="color">@android:color/white</item>
    </style>

    <style name="OverflowButtonStyle" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">@android:color/white</item>
    </style>

    <style name="ArchosThemeBlue" parent="ArchosTheme">
        <item name="android:windowBackground">@drawable/background_2014</item>
        <item name="colorAccent">@color/green_accent</item>
        <item name="android:colorAccent">@color/green_accent</item>
    </style>

    <style name="PrivateDarkBlueTheme" parent="ArchosTheme">
        <item name="android:windowBackground">@drawable/background_2014_private</item>
        <item name="colorAccent">@color/green_accent</item>
        <item name="android:colorAccent">@color/green_accent</item>
    </style>

    <style name="DarkBlueTheme" parent="ArchosTheme">
        <item name="android:windowBackground">@drawable/background_2014_dark</item>
        <item name="colorAccent">@color/green_accent</item>
        <item name="android:colorAccent">@color/green_accent</item>
    </style>

    <style name="Theme.AlertDialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="colorPrimary">@color/lightblue500</item>
        <item name="colorPrimaryDark">#002642</item>
        <item name="colorAccent">@color/lightblue400</item>
    </style>

    <style name="ArchosThemeBlueOverlay" parent="ArchosThemeBlue">
        <item name="windowActionBarOverlay">true</item>
    </style>

    <style name="ArchosThemeBlueTransparent" parent="ArchosThemeBlue">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:fontFamily">@font/nhaasgroteskdspro_75bd</item>
    </style>

    <style name="Theme.TransparentCompat" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="colorPrimary">@color/lightblue500</item>
        <item name="colorAccent">@color/lightblue400</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="alertDialogTheme">@style/Theme.AlertDialog</item>
        <item name="android:navigationBarColor">#001b30</item>
        <item name="actionOverflowMenuStyle">@style/CustomPopupMenu</item>
    </style>

    <style name="Theme.Transparent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <style name="Theme.DialogMinWidth" parent="Theme.AppCompat.Dialog.MinWidth">
        <item name="colorPrimary">@color/lightblue500</item>
        <item name="colorAccent">@color/lightblue200</item>
        <item name="alertDialogTheme">@style/Theme.AlertDialog</item>
    </style>

    <style name="AppTheme" parent="Theme.AppCompat">
        <!-- Your existing theme items -->
        <item name="popupMenuStyle">@style/CustomPopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/CustomPopupMenu</item>
        <!-- Add these for checkable menu items -->
        <item name="colorAccent">@color/green_accent</item>
        <item name="android:colorAccent">@color/green_accent</item>
    </style>

    <style name="PlayerActivityTheme" parent="Theme.AppCompat">
        <item name="actionOverflowMenuStyle">@style/CustomPopupMenu</item>
        <item name="popupMenuStyle">@style/CustomPopupMenu</item>
        <item name="android:actionOverflowMenuStyle">@style/CustomPopupMenu</item>
        <item name="android:popupMenuStyle">@style/CustomPopupMenu</item>
        <item name="colorAccent">@color/green_accent</item>
        <item name="android:colorAccent">@color/green_accent</item>
        <item name="android:itemBackground">@drawable/overflow_menu_item_ripple</item>
        <item name="android:listSelector">@drawable/overflow_menu_item_ripple</item>
    </style>

    <style name="CustomOverFlowMenu" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:popupBackground">@drawable/menu_bg</item>
        <item name="colorAccent">@color/green_accent</item>
        <item name="android:colorAccent">@color/green_accent</item>
        <item name="android:itemBackground">@drawable/overflow_menu_item_ripple</item>
        <item name="android:listSelector">@drawable/overflow_menu_item_ripple</item>
    </style>

    <style name="CustomPopupMenu" parent="Widget.AppCompat.PopupMenu.Overflow"><!-- player is one of use cases -->
        <item name="android:popupBackground">@drawable/menu_bg</item>
        <item name="colorAccent">@color/green_accent</item>
        <item name="android:colorAccent">@color/green_accent</item>
    </style>

    <style name="Theme.CustomDialogMinWidth" parent="Theme.AppCompat.Dialog.MinWidth">
        <item name="colorPrimary">@color/lightblue500</item>
        <item name="colorAccent">@color/green_accent</item>
        <item name="alertDialogTheme">@style/Theme.AlertDialog</item>
        <item name="android:windowBackground">@drawable/menu_bg</item> <!-- custom background -->
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:textColorPrimary">@color/red</item>
        <item name="android:fontFamily">@font/nhaasgroteskdspro_95blk</item>
        <!-- <item name="android:textColor">@color/red</item>  apply your text color -->
    </style>
</resources>
